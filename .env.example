# useSend — self-hosted Resend alternative (https://usesend.com)
# API key from your instance: Developer Settings → API Keys (starts with us_)
USESEND_API_KEY=us_xxxxxxxxxxxxxxxxxxxxxxxx

# Your self-hosted useSend instance (no trailing slash).
# Defaults to the hosted cloud if unset.
USESEND_BASE_URL=https://send.cwcodes.de

# Optional (Defaults sind im Code hinterlegt):
# Adresse, die Kontaktanfragen empfängt
# CONTACT_TO_EMAIL=connor@cwcodes.de
# Absender — Domain muss in useSend verifiziert sein
# CONTACT_FROM_EMAIL=connor@cwcodes.de
# CONTACT_FROM_NAME=CWCODES
