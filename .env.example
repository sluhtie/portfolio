# Brevo — https://www.brevo.com  (Dashboard → SMTP & API → API Keys → Generate)
# Wird von der Serverless-Funktion api/contact.ts benutzt.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (Defaults sind im Code hinterlegt):
# Adresse, die Kontaktanfragen empfängt
# CONTACT_TO_EMAIL=connor@cwcodes.de
# Absender — MUSS in Brevo als Sender verifiziert sein (per Klick-Link, keine Domain nötig)
# CONTACT_FROM_EMAIL=connor@cwcodes.de
# CONTACT_FROM_NAME=CWCODES
