# Resend — https://resend.com  (Dashboard → API Keys → Create)
# Wird von der Serverless-Funktion api/contact.ts benutzt.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (Defaults sind im Code hinterlegt):
# Adresse, die Kontaktanfragen empfängt
# CONTACT_TO_EMAIL=connor@cwcodes.de
# Absender — MUSS eine in Resend verifizierte Domain sein (cwcodes.de)
# CONTACT_FROM_EMAIL=CWCODES <noreply@cwcodes.de>
